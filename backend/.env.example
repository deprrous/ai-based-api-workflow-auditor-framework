AUDITOR_APP_NAME=AI API Workflow Auditor
AUDITOR_ENV=development
AUDITOR_VERSION=0.1.0
AUDITOR_DEBUG=true
AUDITOR_API_PREFIX=/api/v1
AUDITOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUDITOR_DATABASE_URL=postgresql+psycopg://auditor:auditor@127.0.0.1:5432/auditor
AUDITOR_DATABASE_AUTO_CREATE=true
AUDITOR_SEED_DATA=true
AUDITOR_SSE_POLL_INTERVAL=1.0
AUDITOR_INGEST_TOKENS=dev-ingest-token
AUDITOR_ADMIN_TOKENS=dev-admin-token
