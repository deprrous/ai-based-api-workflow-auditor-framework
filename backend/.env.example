AUDITOR_APP_NAME=AI API Workflow Auditor
AUDITOR_ENV=development
AUDITOR_VERSION=0.1.0
AUDITOR_DEBUG=true
AUDITOR_API_PREFIX=/api/v1
AUDITOR_CORS_ORIGINS=http://localhost:3000,http://127.0.0.1:3000
AUDITOR_DATABASE_URL=postgresql+psycopg://auditor:auditor@127.0.0.1:5432/auditor
AUDITOR_DATABASE_AUTO_CREATE=true
AUDITOR_SEED_DATA=true
AUDITOR_SSE_POLL_INTERVAL=1.0
AUDITOR_INGEST_TOKENS=dev-ingest-token
AUDITOR_ADMIN_TOKENS=dev-admin-token
AUDITOR_VERIFIER_AUTORUN_ENABLED=false
AUDITOR_VERIFIER_AUTORUN_MODE=disabled
AUDITOR_VERIFIER_AUTORUN_POLL_INTERVAL=2.0
AUDITOR_VERIFIER_AUTORUN_WORKER_ID=verifier-autorun
AUDITOR_VERIFIER_REPLAY_BASE_URL=
AUDITOR_VERIFIER_REPLAY_TIMEOUT=5.0
AUDITOR_VERIFIER_REPLAY_VERIFY_TLS=true
AUDITOR_VERIFIER_REPLAY_ACTOR_HEADERS_JSON={}
AUDITOR_REPLAY_ARTIFACT_RETENTION_HOURS=72
AUDITOR_REPLAY_ARTIFACT_RETENTION_AUTORUN_ENABLED=true
AUDITOR_REPLAY_ARTIFACT_RETENTION_POLL_INTERVAL=300
AUDITOR_REPLAY_ARTIFACT_REDACT_HEADERS=authorization,cookie,set-cookie,x-api-key,api-key,x-auth-token
AUDITOR_REPLAY_ARTIFACT_REDACT_BODY_KEYS=password,passwd,secret,token,api_key,access_token,refresh_token,client_secret,authorization,cookie,session,jwt
